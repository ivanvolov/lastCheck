# Telegram
TELEGRAM_TOKEN=

# Arbitrum RPC
ETH_RPC_URL=

# Agent signer key (auto-generated on first start if not set)
# AGENT_PRIVATE_KEY=0x...

# Gnosis Safe address on Arbitrum (set after Safe is created; editable in dashboard Settings)
SAFE_ADDRESS=

# First signer wallet address (owner of the Safe)
FIRST_SIGNER=

# OpenAI (for voice transcription)
OPENAI_API_KEY=sk-...

# Tenderly simulation (optional — enables accurate token_out_usd)
TENDERLY_ACCESS_KEY=
TENDERLY_ACCOUNT_SLUG=
TENDERLY_PROJECT_SLUG=
TENDERLY_NETWORK_ID=

# Dashboard
DASHBOARD_PORT=8501
