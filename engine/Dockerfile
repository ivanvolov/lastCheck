FROM python:3.11-slim

WORKDIR /app

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Python deps
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Source
COPY . .

# Expose dashboard port
EXPOSE 8501

# Default: start both the bot and the dashboard
CMD ["sh", "-c", "streamlit run dashboard/app.py --server.port 8501 --server.address 0.0.0.0 & python -m bot.telegram_bot"]
